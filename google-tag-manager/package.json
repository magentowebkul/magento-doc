{
  "name": "magento2-google-tag-manager-docs",
  "description": "User guide documentation for the Webkul Magento 2 Google Tag Manager extension.",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "npx-update": "npx npm-check-updates -u",
    "npm_install": "npm install --force",
    "build": "vuepress build docs --clean-cache --clean-temp",
    "build:site": "VUEPRESS_BASE=/google-tag-manager/ vuepress build docs --clean-cache --clean-temp",
    "deploy:cloudflare": "npm run build:site && npx wrangler pages deploy docs/.vuepress/dist --project-name magento-doc --branch main --commit-dirty=true",
    "start": "vuepress dev docs --clean-cache --clean-temp -p 8098",
    "docs": "vuepress dev docs --clean-cache --clean-temp",
    "clean": "rm -rf docs/.vuepress/.cache docs/.vuepress/.temp docs/.vuepress/dist",
    "fresh": "npm run clean && npm run build",
    "docs:update-package": "npx vp-update"
  },
  "devDependencies": {
    "@vuepress/bundler-webpack": "2.0.0-rc.20",
    "@vuepress/plugin-pwa": "2.0.0-rc.86",
    "@vuepress/plugin-search": "2.0.0-rc.86",
    "@vuepress/theme-default": "2.0.0-rc.88",
    "mermaid": "^11.14.0",
    "playwright": "^1.61.1",
    "sass-embedded": "^1.98.0",
    "sass-loader": "^16.0.7",
    "vue": "^3.5.31",
    "vuepress": "2.0.0-rc.20",
    "vuepress-plugin-md-enhance": "^2.0.0-rc.72"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
